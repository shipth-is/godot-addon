[node name="VerifyButton" type="Button" parent="CodeContainer"]
layout_mode = 2
text = "Submit code →"

[node name="BackLink" type="LinkButton" parent="CodeContainer"]
layout_mode = 2
text = "← Use different email"

[node name="AgreementWrapper" type="MarginContainer" parent="."]
