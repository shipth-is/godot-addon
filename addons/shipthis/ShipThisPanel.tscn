[node name="ShipThisPanel" type="VBoxContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_panel")

[node name="EmailContainer" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 8

[node name="HeadingLabel" type="Label" parent="EmailContainer"]
layout_mode = 2
text = "Enter your email"

[node name="EmailInput" parent="EmailContainer" instance=ExtResource("4_submit_line_edit")]
layout_mode = 2
placeholder_text = "your@email.com"

[node name="SubtextLabel" type="Label" parent="EmailContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 12
text = "We will email you a one-time code. If you are new, we will create your account automatically."

[node name="SendCodeButton" type="Button" parent="EmailContainer"]
layout_mode = 2
text = "Send code →"

[node name="CodeContainer" type="VBoxContainer" parent="."]
visible = false
layout_mode = 2
theme_override_constants/separation = 8

[node name="CodePromptLabel" type="Label" parent="CodeContainer"]
layout_mode = 2
text = "Please enter the code we sent to your@email.com."

[node name="CodeInput" parent="CodeContainer" instance=ExtResource("4_submit_line_edit")]
layout_mode = 2
